{
  "name": "albo",
  "private": true,
  "packageManager": "npm@9.9.3",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev -w @albo/web",
    "dev:workers": "npm run dev -w @albo/workers",
    "dev:mastra": "npm run dev -w @albo/mastra",
    "build:web": "npm run build -w @albo/web",
    "build:workers": "npm run build -w @albo/workers",
    "build:mastra": "npm run build -w @albo/mastra",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "turbo": "^2.5.0"
  }
}
